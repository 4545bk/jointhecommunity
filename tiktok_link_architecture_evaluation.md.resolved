#### Soft Redirect Page Implementation (`/go/website`)

```jsx
// pages/go/website.js (Next.js)
import { useEffect, useState } from 'react';
import Head from 'next/head';

const DESTINATION = 'https://www.yourbrand.com';
const DELAY_MS = 3000;

export default function RedirectToWebsite() {
  const [progress, setProgress] = useState(0);
  const [timeLeft, setTimeLeft] = useState(3);

  useEffect(() => {
    // Smooth progress bar
    const progressInterval = setInterval(() => {
      setProgress((prev) => Math.min(prev + 1, 100));
    }, DELAY_MS / 100);

    // Countdown
    const countdownInterval = setInterval(() => {
      setTimeLeft((prev) => Math.max(prev - 1, 0));
    }, 1000);

    // Navigate after delay
    const timeout = setTimeout(() => {
      window.location.href = DESTINATION;
    }, DELAY_MS);

    return () => {
      clearInterval(progressInterval);
      clearInterval(countdownInterval);
      clearTimeout(timeout);
    };
  }, []);

  return (
    <>
      <Head>
        {/* Real page title — no "redirect" language in metadata */}
        <title>YourBrand — Continue to Website</title>
        <meta name="robots" content="noindex, nofollow" />
      </Head>

      <main className="redirect-container">
        <div className="redirect-card">
          <img src="/logo.svg" alt="YourBrand" className="brand-logo" />
          <h1>You're heading to YourBrand</h1>
          <p className="subtitle">
            You'll be redirected in {timeLeft} second{timeLeft !== 1 ? 's' : ''}
          </p>
          <div className="progress-track">
            <div 
              className="progress-fill" 
              style={{ width: `${progress}%` }} 
            />
          </div>
          <a href={DESTINATION} className="manual-link">
            Click here if not redirected automatically
          </a>
        </div>
      </main>
    </>
  );
}
```

> [!NOTE]
> **Why `noindex, nofollow`?** The redirect page has no SEO value. Telling search engines to ignore it prevents it from appearing in SERPs and avoids any "thin content" penalties. TikTok's crawler is NOT a search engine crawler — it does not obey `robots` meta tags. This directive is purely for Google/Bing.

#### Link-in-Bio Page Implementation (`/`)

```jsx
// pages/index.js
import Head from 'next/head';

const LINKS = [
  {
    id: 'website',
    label: '🌐 Visit Our Website',
    href: '/go/website',        // Internal soft redirect
    external: false,
  },
  {
    id: 'telegram',
    label: '✈️ Join Our Telegram',
    href: 'https://t.me/yourbrand',  // Direct external link
    external: true,
  },
  {
    id: 'instagram',
    label: '📸 Follow on Instagram',
    href: 'https://instagram.com/yourbrand',
    external: true,
  },
  {
    id: 'support',
    label: '📧 Contact Support',
    href: 'mailto:support@yourbrand.com',
    external: true,
  },
];

export default function LinkInBio() {
  const trackClick = (linkId) => {
    // First-party analytics — see Section 6.4
    navigator.sendBeacon('/api/track', JSON.stringify({
      event: 'link_click',
      linkId,
      timestamp: Date.now(),
      referrer: document.referrer,
    }));
  };

  return (
    <>
      <Head>
        <title>YourBrand — Links</title>
        <meta name="description" content="Official links for YourBrand. 
          Visit our website, join our community, and connect with us." />
      </Head>

      <main className="linkinbio-container">
        <div className="profile-section">
          <img src="/avatar.jpg" alt="YourBrand" className="avatar" />
          <h1>YourBrand</h1>
          <p className="bio">Your compelling one-liner here</p>
        </div>

        <nav className="links-list" aria-label="External links">
          {LINKS.map((link) => (
            <a
              key={link.id}
              id={`link-${link.id}`}
              href={link.href}
              target={link.external ? '_blank' : '_self'}
              rel={link.external ? 'noopener noreferrer' : undefined}
              className="link-button"
              onClick={() => trackClick(link.id)}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <footer className="footer">
          <p>© {new Date().getFullYear()} YourBrand. All rights reserved.</p>
        </footer>
      </main>
    </>
  );
}
```

